    "weblegko_faq_6jEpVy": {
      "type": "weblegko-faq",
      "blocks": {
        "question_iCm6cA": {
          "type": "question",
          "settings": {
            "question": "What is your return policy?",
            "answer": "<p>We accept returns within 30 days of purchase. Items must be in their original condition, unused, and with all tags attached. Refunds are processed within 5-7 business days.</p>"
          }
        },
        "question_kPPJdK": {
          "type": "question",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "<p>Standard shipping typically takes 3-5 business days within the US. Express shipping is available for 1-2 business day delivery. International shipping times vary by destination.</p>"
          }
        },
        "question_4THbUX": {
          "type": "question",
          "settings": {
            "question": "Do you ship internationally?",
            "answer": "<p>Yes, we ship to over 50 countries worldwide. International shipping rates and delivery times are calculated at checkout based on your location.</p>"
          }
        },
        "question_Gm6DQm": {
          "type": "question",
          "settings": {
            "question": "What payment methods do you accept?",
            "answer": "<p>We accept all major credit cards (Visa, MasterCard, American Express), PayPal, Apple Pay, Google Pay, and Shop Pay. All transactions are secure and encrypted.</p>"
          }
        },
        "question_UKkGB7": {
          "type": "question",
          "settings": {
            "question": "How can I track my order?",
            "answer": "<p>Once your order ships, you'll receive a confirmation email with a tracking number. You can also track your order in your account dashboard under 'Order History'.</p>"
          }
        },
        "question_McaDeH": {
          "type": "question",
          "settings": {
            "question": "Do you offer discounts for bulk orders?",
            "answer": "<p>Yes, we offer volume discounts for bulk orders over $500. Please contact our sales team at sales@yourstore.com for a custom quote based on your requirements.</p>"
          }
        },
        "question_aCMmQG": {
          "type": "question",
          "settings": {
            "question": "Is my personal information secure?",
            "answer": "<p>Absolutely! We use industry-standard SSL encryption to protect your data. We never store your payment information, and we never share your personal details with third parties.</p>"
          }
        }
      },
