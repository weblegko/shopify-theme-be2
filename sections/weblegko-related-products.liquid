<!-- sections/weblegko-related-products.liquid -->

{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'section-related-products.css' | asset_url | stylesheet_tag }}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

{%- unless section.settings.quick_add == 'none' -%}
  {{ 'quick-add.css' | asset_url | stylesheet_tag }}
{%- endunless -%}

{%- if section.settings.quick_add == 'standard' -%}
  <script src="{{ 'quick-add.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'product-form.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{%- if section.settings.quick_add == 'bulk' -%}
  <script src="{{ 'quick-add-bulk.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quantity-popover.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'price-per-item.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'quick-order-list.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

<style>
  /* ============================================ */
  /* ПАДДИНГИ СЕКЦИИ (rem) - inline стили */
  /* ============================================ */
  .weblegko-related-padding {
    padding-top: {{ section.settings.padding_top_mobile | default: 3 }}rem !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 3 }}rem !important;
  }

  @media screen and (min-width: 640px) {
    .weblegko-related-padding {
      padding-top: {{ section.settings.padding_top_tablet | default: 5 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_tablet | default: 5 }}rem !important;
    }
  }

  @media screen and (min-width: 1024px) {
    .weblegko-related-padding {
      padding-top: {{ section.settings.padding_top_desktop | default: 8 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 8 }}rem !important;
    }
  }

  /* ============================================ */
  /* CSS GRID С БРЕЙКПОИНТАМИ (колонки, gap) */
  /* ============================================ */

  /* Базово: настройки для мобильных */
  #weblegko-related-grid {
    display: grid !important;
    grid-template-columns: repeat({{ section.settings.columns_mobile | default: 1 }}, 1fr) !important;
    gap: {{ section.settings.row_gap_mobile | default: 1 }}rem {{ section.settings.col_gap_mobile | default: 1 }}rem !important;
    width: 100% !important;
    list-style: none !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  #weblegko-related-grid .grid__item {
    width: 100% !important;
    min-width: 0 !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
    display: flex !important;
    flex-direction: column !important;
  }

  /* Брейкпоинт: планшеты (640px - 1023px) */
  @media screen and (min-width: 640px) and (max-width: 1023px) {
    #weblegko-related-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 2 }}, 1fr) !important;
      gap: {{ section.settings.row_gap_tablet | default: 1.5 }}rem {{ section.settings.col_gap_tablet | default: 1.5 }}rem !important;
    }
  }

  /* Брейкпоинт: десктопы (1024px+) */
  @media screen and (min-width: 1024px) {
    #weblegko-related-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, 1fr) !important;
      gap: {{ section.settings.row_gap_desktop | default: 2 }}rem {{ section.settings.col_gap_desktop | default: 2 }}rem !important;
    }
  }

  .section-related-weblegko{
    max-height: 1000rem;
    visibility: visible;
    height: initial;
    transition: all 1s ease-in-out;
  }

  /* Скрываем секцию если нет товаров */
  .weblegko-related--hidden {
    max-height: 0;
    visibility: hidden;
    opacity:0;
    height: 0;
  }

  /* ============================================ */
  /* Скрытие лишних карточек на брейкпоинтах */
  /* ============================================ */

  /* Мобильные (< 640px) */
  @media screen and (max-width: 639px) {
    .weblegko-hide-mobile {
      display: none !important;
    }
  }

  /* Планшеты (640px - 1023px) */
  @media screen and (min-width: 640px) and (max-width: 1023px) {
    .weblegko-hide-tablet {
      display: none !important;
    }
  }

  /* Десктопы (>= 1024px) */
  @media screen and (min-width: 1024px) {
    .weblegko-hide-desktop {
      display: none !important;
    }
  }
</style>

{%- comment -%}
  Определяем сколько товаров показывать на каждом брейкпоинте
{%- endcomment -%}
{%- assign products_limit = section.settings.products_to_show | default: 12 -%}
{%- assign desktop_limit = section.settings.products_to_show_desktop | default: products_limit -%}
{%- assign tablet_limit = section.settings.products_to_show_tablet | default: products_limit -%}
{%- assign mobile_limit = section.settings.products_to_show_mobile | default: products_limit -%}

<section class="section-related-weblegko tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem] ">
  <div class="weblegko-related-padding tw:max-w-[112rem] tw:mx-auto">
    <!-- Заголовок -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[2.5rem] tw:md:mb-[3rem]">
        <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.33] tw:lg:leading-[1.2] tw:text-center">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
            <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:tw:text-center">
              {{ section.settings.description }}
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Сетка товаров через product-recommendations -->
    <product-recommendations
      class="related-products"
      data-url="{{ routes.product_recommendations_url }}?limit={{ products_limit }}&intent=related"
      data-section-id="{{ section.id }}"
      data-product-id="{{ product.id }}"
    >
      {% if recommendations.performed and recommendations.products_count > 0 %}
        <ul
          id="weblegko-related-grid"
          role="list"
          class="product-grid"
        >
          {% assign skip_card_product_styles = false %}

          {%- comment -%}
            Показываем все товары, но скрываем лишние через CSS на разных брейкпоинтах
          {%- endcomment -%}
          {% for recommendation in recommendations.products %}
            {%- assign item_index = forloop.index -%}
            <li
              class="
                grid__item
                {% if item_index > mobile_limit %}weblegko-hide-mobile{% endif %}
                {% if item_index > tablet_limit %}weblegko-hide-tablet{% endif %}
                {% if item_index > desktop_limit %}weblegko-hide-desktop{% endif %}
              "
            >
              {% render 'card-product',
                card_product: recommendation,
                media_aspect_ratio: section.settings.image_ratio,
                image_shape: section.settings.image_shape,
                show_secondary_image: section.settings.show_secondary_image,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                skip_styles: skip_card_product_styles,
                quick_add: section.settings.quick_add,
                section_id: section.id
              %}
            </li>
            {%- assign skip_card_product_styles = true -%}
          {% endfor %}
        </ul>
      {% endif %}
    </product-recommendations>
  </div>
</section>

<!-- 10 попыток за 5 секунд на загрузку товаров через аякс -->
<script>
  let attempts = 0;
  let maxAttempts = 10;
  const section = document.querySelector('.section-related-weblegko');
  section.classList.add('weblegko-related--hidden');
  let timer = setInterval(() => {
    attempts++;
    if (document.querySelector('#weblegko-related-grid')) {
      console.log('есть товары - показываем');
      section.classList.remove('weblegko-related--hidden');
      clearInterval(timer);
    } else {
      console.log('нет товаров - скрываем');
      section.classList.add('weblegko-related--hidden');
      if (attempts >= maxAttempts) {
        clearInterval(timer);
      }
    }
  }, 500);
</script>

