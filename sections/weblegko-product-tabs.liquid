<!-- sections/weblegko-product-tabs.liquid -->
{{ 'weblegko-typo.css' | asset_url | stylesheet_tag }}

<style>
  .weblegko-tabs-padding {
    padding-top: {{ section.settings.padding_top_mobile | default: 3 }}rem !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 3 }}rem !important;
  }

  @media screen and (min-width: 640px) {
    .weblegko-tabs-padding {
      padding-top: {{ section.settings.padding_top_tablet | default: 5 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_tablet | default: 5 }}rem !important;
    }
  }

  @media screen and (min-width: 1024px) {
    .weblegko-tabs-padding {
      padding-top: {{ section.settings.padding_top_desktop | default: 8 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 8 }}rem !important;
    }
  }

  .weblegko-tab-btn {
    padding: 2rem 0 1.5rem;
    font-weight: 500;
    font-size: 1.4rem;
    line-height: 143%;
    letter-spacing: -0.04em;
    color: #596173;
    background: transparent;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
    position: relative;
  }

  .weblegko-tab-btn:hover {
    color: #ffc356;
  }

  .weblegko-tab-btn.active {
    color: #00b5d1;
    font-weight: 600;
  }

  .weblegko-tab-btn.active::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 0;
    right: 0;
    height: 2px;
    background: #00b5d1;
  }

  .weblegko-tab-content {
    display: none;
    animation: fadeIn 0.3s ease;
  }

  .weblegko-tab-content.active {
    display: block;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

</style>

{%- liquid
  assign tabs_data = product.description
  assign has_content = false

  if tabs_data != blank
    assign has_content = true
  endif
-%}


{% if has_content %}
  <section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
    <div class="tw:max-w-[112rem] tw:mx-auto weblegko-tabs-padding">
      <!-- Заголовок секции -->
      {%- if section.settings.heading != blank -%}
        <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.2] tw:text-center tw:mb-[3rem]">
          {{ section.settings.heading }}
        </h2>
      {%- endif -%}

      <div class="tw:rounded-t-[1.6rem] tw:bg-white tw:border-b tw:border-[#e5e5e5]">
        <!-- Кнопки табов -->
        <div class="tw:flex tw:gap-[1.6rem] tw:px-[1.6rem] tw:flex-nowrap" role="tablist">
          <button
            class="weblegko-tab-btn active"
            data-tab="tab-1"
            role="tab"
            aria-selected="true"
            aria-controls="tab-1"
            id="btn-tab-1"
          >
            Summary
          </button>
        </div>
      </div>

      <div class="tw:rounded-b-[1.6rem] tw:bg-white tw:px-[1.6rem] tw:py-[1.6rem]">
        <!-- ======================================== -->
        <!-- TAB 1: DESCRIPTION (ВСЁ ОПИСАНИЕ)        -->
        <!-- ======================================== -->
        <div class="typo weblegko-tab-content active tab-content-inner" id="tab-1" role="tabpanel" aria-labelledby="btn-tab-1">
          {{ tabs_data }}
        </div>
      </div>
    </div>
  </section>

  <script>
    document.addEventListener('DOMContentLoaded', function () {
      const tabs = document.querySelectorAll('.weblegko-tab-btn');
      const contents = document.querySelectorAll('.weblegko-tab-content');

      if (tabs.length === 0) return;

      tabs.forEach(function (tab) {
        tab.addEventListener('click', function () {
          tabs.forEach(function (t) {
            t.classList.remove('active');
            t.setAttribute('aria-selected', 'false');
          });
          contents.forEach(function (c) {
            c.classList.remove('active');
          });

          this.classList.add('active');
          this.setAttribute('aria-selected', 'true');

          var targetId = this.getAttribute('data-tab');
          var target = document.getElementById(targetId);
          if (target) {
            target.classList.add('active');
          }
        });
      });
    });
  </script>
{% endif %}

{% schema %}
{
  "name": "WEBLEGKO PRODUCT TABS",
  "tag": "section",
  "class": "section-product-tabs",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Product Details",
      "label": "Section Heading"
    },
    {
      "type": "header",
      "content": "🖥️ Desktop (≥ 1024px)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 8,
      "unit": "rem",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 8,
      "unit": "rem",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "💻 Tablet (640px - 1024px)"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "default": 5,
      "unit": "rem",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "default": 5,
      "unit": "rem",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "📱 Mobile (< 640px)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 3,
      "unit": "rem",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 3,
      "unit": "rem",
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO PRODUCT TABS",
      "category": "Product"
    }
  ]
}
{% endschema %}