<!-- sections/weblegko-resources.liquid -->

<style>
  /* ============================================ */
  /* ПАДДИНГИ СЕКЦИИ (rem) - inline стили */
  /* ============================================ */
  .weblegko-resources-padding {
    padding-top: {{ section.settings.padding_top_mobile | default: 3 }}rem !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 3 }}rem !important;
  }

  @media screen and (min-width: 640px) {
    .weblegko-resources-padding {
      padding-top: {{ section.settings.padding_top_tablet | default: 5 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_tablet | default: 5 }}rem !important;
    }
  }

  @media screen and (min-width: 1024px) {
    .weblegko-resources-padding {
      padding-top: {{ section.settings.padding_top_desktop | default: 8 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 8 }}rem !important;
    }
  }

  /* ============================================ */
  /* GRID С БРЕЙКПОИНТАМИ (колонки, gap, initial items) */
  /* ============================================ */

  #resources-grid {
    display: grid !important;
    grid-template-columns: repeat({{ section.settings.columns_mobile | default: 1 }}, 1fr) !important;
    gap: {{ section.settings.row_gap_mobile | default: 1.2 }}rem {{ section.settings.col_gap_mobile | default: 1.2 }}rem !important;
    --grid-cols: {{ section.settings.columns_mobile | default: 1 }};
    --initial-items: {{ section.settings.initial_items_mobile | default: 1 }};
  }

  @media screen and (min-width: 640px) and (max-width: 1023px) {
    #resources-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 2 }}, 1fr) !important;
      gap: {{ section.settings.row_gap_tablet | default: 1.5 }}rem {{ section.settings.col_gap_tablet | default: 1.5 }}rem !important;
      --grid-cols: {{ section.settings.columns_tablet | default: 2 }};
      --initial-items: {{ section.settings.initial_items_tablet | default: 2 }};
    }
  }

  @media screen and (min-width: 1024px) {
    #resources-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 2 }}, 1fr) !important;
      gap: {{ section.settings.row_gap_desktop | default: 2 }}rem {{ section.settings.col_gap_desktop | default: 2 }}rem !important;
      --grid-cols: {{ section.settings.columns_desktop | default: 2 }};
      --initial-items: {{ section.settings.initial_items_desktop | default: 2 }};
    }
  }

  /* ============================================ */
  /* Анимация появления */
  /* ============================================ */
  @keyframes fadeGrowIn {
    from {
      opacity: 0;
      transform: translateY(2rem) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .resource-item-animate {
    animation: fadeGrowIn 0.5s ease-out forwards;
  }
</style>

<noscript>
  <style>
    .resource-item.tw\:hidden {
      display: block !important;
    }
    #resources-show-more-btn {
      display: none !important;
    }
  </style>
</noscript>

<section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
  <div class="weblegko-resources-padding tw:max-w-[112rem] tw:mx-auto">
    <!-- Заголовок секции -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[2.5rem] tw:md:mb-[3rem]">
        <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.33] tw:md:leading-[1.2] tw:text-center">
          {{ section.settings.heading }}
        </h2>

        {%- if section.settings.description != blank -%}
          <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
            <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:text-center">
              {{ section.settings.description }}
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <!-- Сетка карточек -->
    <div
      id="resources-grid"
      class="{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      {% if settings.animations_reveal_on_scroll %}
        data-cascade
        style="--animation-order: {{ forloop.index }};"
      {% endif %}
    >
      {%- for block in section.blocks -%}
        <div class="resource-item tw:hidden" {{ block.shopify_attributes }}>
          <!-- КАРТОЧКА -->
          <a
            href="{{ block.settings.button_link }}"
            class="tw:hover:shadow-lg tw:transition-all tw:duration-300 tw:p-[1rem] tw:bg-white tw:rounded-xl tw:overflow-hidden tw:flex tw:flex-row tw:h-full"
          >
            <!-- Левая часть: Картинка (47%) -->
            <div class="tw:w-[47%] tw:shrink-0 tw:overflow-hidden">
              {%- if block.settings.resource_image != blank -%}
                {%- assign img_width = 600 -%}
                {%- assign img_height = img_width | divided_by: block.settings.resource_image.aspect_ratio -%}
                <img
                  src="{{ block.settings.resource_image | image_url: width: 600 }}"
                  alt="{{ block.settings.title | escape }}"
                  width="{{ img_width }}"
                  height="{{ img_height }}"
                  class="tw:w-full tw:h-auto tw:object-cover tw:rounded-[1rem] tw:border tw:border-slate-200"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'image' | placeholder_svg_tag: 'tw:w-full tw:h-full' }}
              {%- endif -%}
            </div>

            <!-- Правая часть: Описание (53%) -->
            <div class="tw:w-[53%] tw:pl-[1rem] tw:lg:pl-[2rem] tw:flex tw:flex-col">
              <div class="tw:flex tw:flex-col tw:gap-[0.5rem] tw:sm:gap-[1rem] tw:mb-[1rem]">
                <!-- Ряд 1: Бейджик -->
                {%- if block.settings.badge != blank -%}
                  <div>
                    <span class="tw:inline-block tw:text-additional-orange tw:bg-additional-orange-light tw:text-[1.4rem] tw:tracking-[-0.04em] tw:leading-[1] tw:px-[0.8rem] tw:py-[0.4rem] tw:rounded-[0.4rem]">
                      {{ block.settings.badge }}
                    </span>
                  </div>
                {%- endif -%}

                <!-- Ряд 2: Заголовок -->
                {%- if block.settings.title != blank -%}
                  <h3 class="tw:text-[1.4rem] tw:lg:text-[2rem] tw:font-bold tw:tracking-[-0.04em] tw:leading-[1.3]">
                    {{ block.settings.title }}
                  </h3>
                {%- endif -%}

                <!-- Ряд 3: Дата -->
                {%- if block.settings.publish_date != blank -%}
                  <p class="tw:text-[1.3rem] tw:lg:text-[1.4rem] tw:tracking-[-0.04em] tw:leading-[1.23]">
                    <span class="tw:text-grayscale-400">Published: </span>
                    {{ block.settings.publish_date }}
                  </p>
                {%- endif -%}

                <!-- Ряд 4: Категория -->
                {%- if block.settings.category != blank -%}
                  <p class="tw:text-[1.3rem] tw:lg:text-[1.4rem] tw:tracking-[-0.04em] tw:leading-[1.23]">
                    <span class="tw:text-grayscale-400">Categories:</span>
                    {{ block.settings.category }}
                  </p>
                {%- endif -%}
              </div>

              <!-- Ряд 5: Кнопка (прижата к низу) -->
              <div class="tw:mt-auto">
                <div class="tw:flex tw:items-center tw:justify-center tw:rounded-full tw:transition-colors tw:duration-300 tw:ease-in-out tw:hover:bg-golden tw:pt-1 tw:px-[1.6rem] tw:h-[3.2rem] tw:sm:h-[4rem] tw:md:h-[3.2rem] tw:lg:h-[4rem] tw:bg-grayscale-50 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium">
                  {{ block.settings.button_label | default: 'Learn More' }}
                </div>
              </div>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>

    <!-- Кнопка Show More -->
    {%- if section.blocks.size > 0 -%}
      <div class="tw:flex tw:justify-center">
        <button
          type="button"
          id="resources-show-more-btn"
          class="tw:mt-[4rem] tw:inline-flex tw:items-center tw:justify-center tw:rounded-full tw:transition-colors tw:duration-300 tw:ease-in-out tw:hover:bg-golden tw:px-[1.6rem] tw:pt-1 tw:h-[3.6rem] tw:bg-white tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium tw:shadow-md disabled:tw:opacity-70 disabled:tw:cursor-not-allowed"
        >
          <!-- Спиннер загрузки -->
          <svg
            id="resources-loader"
            class="tw:hidden tw:animate-spin tw:mr-2 tw:h-5 tw:w-5 tw:text-goluboydark"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle class="tw:opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="tw:opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span id="resources-btn-text">Show More Resources</span>
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  function initResources() {
    const grid = document.getElementById('resources-grid');
    const btn = document.getElementById('resources-show-more-btn');
    const loader = document.getElementById('resources-loader');
    const btnText = document.getElementById('resources-btn-text');

    if (!grid || !btn) return;

    const items = grid.querySelectorAll('.resource-item');
    if (items.length === 0) {
      btn.style.display = 'none';
      return;
    }

    // Сброс при Hot Reload
    btn.style.display = '';
    btn.disabled = false;
    if (loader) loader.classList.add('tw:hidden');
    if (btnText) btnText.textContent = 'Show More Resources';

    items.forEach((item) => {
      item.classList.add('tw:hidden');
      item.classList.remove('resource-item-animate');
    });

    grid.dataset.visible = 0;

    function getCSSVar(varName) {
      return parseInt(getComputedStyle(grid).getPropertyValue(varName)) || 1;
    }

    function showItems(count) {
      let currentVisible = parseInt(grid.dataset.visible) || 0;
      const totalToShow = Math.min(currentVisible + count, items.length);

      for (let i = currentVisible; i < totalToShow; i++) {
        items[i].classList.remove('tw:hidden');
        items[i].classList.add('resource-item-animate');
      }

      grid.dataset.visible = totalToShow;

      if (totalToShow >= items.length) {
        btn.style.display = 'none';
      }
    }

    const initialItems = getCSSVar('--initial-items');
    showItems(initialItems);
  }

  // Глобальный слушатель (Event Delegation)
  if (!window.resourcesListenerAdded) {
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('#resources-show-more-btn');
      if (btn && !btn.disabled) {
        const grid = document.getElementById('resources-grid');
        const loader = document.getElementById('resources-loader');
        const btnText = document.getElementById('resources-btn-text');

        if (!grid) return;

        btn.disabled = true;
        if (loader) loader.classList.remove('tw:hidden');
        if (btnText) btnText.textContent = 'Loading...';

        setTimeout(function () {
          if (loader) loader.classList.add('tw:hidden');
          if (btnText) btnText.textContent = 'Show More Resources';
          btn.disabled = false;

          const gridCols = parseInt(getComputedStyle(grid).getPropertyValue('--grid-cols')) || 1;

          let currentVisible = parseInt(grid.dataset.visible) || 0;
          const items = grid.querySelectorAll('.resource-item');
          const totalToShow = Math.min(currentVisible + gridCols, items.length);

          for (let i = currentVisible; i < totalToShow; i++) {
            items[i].classList.remove('tw:hidden');
            items[i].classList.add('resource-item-animate');
          }

          grid.dataset.visible = totalToShow;

          if (totalToShow >= items.length) {
            btn.style.display = 'none';
          }
        }, 1000);
      }
    });
    window.resourcesListenerAdded = true;
  }

  // ЗАПУСК
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initResources);
  } else {
    initResources();
  }

  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.querySelector('#resources-grid')) {
      initResources();
    }
  });
</script>

