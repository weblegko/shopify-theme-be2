{% comment %} ================================================== {% endcomment %}
{% assign all_reviews = shop.metaobjects.custom_product_review.values %}
{% assign total_reviews = all_reviews | size %}
{% assign total_rating_sum = 0 %}

{% for review in all_reviews %}
  {% assign total_rating_sum = total_rating_sum | plus: review.rating %}
{% endfor %}

{% if total_reviews > 0 %}
  {% assign average_rating = total_rating_sum | divided_by: total_reviews %}
  {% assign average_rating_formatted = average_rating | round: 1 %}
{% endif %}

{% if total_reviews > 0 %}
  <div class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
    <div class="weblegko-reviews-padding tw:max-w-[112rem] tw:mx-auto">
      <!-- Заголовок секции -->
      {%- if section.settings.heading != blank -%}
        <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[2.5rem] tw:md:mb-[3rem]">
          <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.2] tw:text-center">
            {{ section.settings.heading }}
          </h2>

          {%- if section.settings.show_stats -%}
            <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
              <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:text-center">
                Rated {{ average_rating_formatted }}/5 · {{ total_reviews }} {{ section.settings.reviews_label | default: 'reviews' }}
              </span>
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {% comment %} ===== ГРИД С КАРТОЧКАМИ ===== {% endcomment %}
      <div
        id="reviews-grid"
        class="{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        {% if settings.animations_reveal_on_scroll %}
          data-cascade
          style="--animation-order: {{ forloop.index }};"
        {% endif %}
      >
        {% for review in all_reviews %}
          <div class="review-item tw:hidden" data-review-index="{{ forloop.index0 }}">
            <a
              href="{{ review.product.url | default: '#' }}"
              class="tw:hover:shadow-lg tw:hover:scale-[101%] tw:transition-all tw:duration-300 tw:bg-white tw:rounded-[1.2rem] tw:p-[1.5rem] tw:h-full tw:flex tw:flex-col"
            >
              <!-- Звезды -->
              <div class="tw:flex tw:gap-1 tw:mb-4">
                {% assign rating_val = review.rating | plus: 0 %}
                {%- for i in (1..rating_val) -%}
                  <svg class="tw:w-[1.8rem] tw:h-[1.8rem] tw:text-goluboydark">
                    <use href="#star"></use>
                  </svg>
                {%- endfor -%}
              </div>

              <!-- Автор и время -->
              <div class="tw:block tw:mb-4">
                <span class="tw:text-[1.6rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.5]">
                  {{ review.author }},
                </span>
                <span>&nbsp;</span>
                <span class="tw:text-[1.6rem] tw:text-[#bcb4a4] tw:tracking-[-0.04em] tw:leading-[1.5]">
                  {{ review.created_at | date: '%d.%m.%Y' }}
                </span>
              </div>

              <!-- Заголовок отзыва (первые 40 символов комментария) -->
              <div class="tw:text-[2rem] tw:leading-[1.4] tw:tracking-[-0.04em] tw:font-medium tw:flex-1 tw:mb-3">
                {{ review.title | strip_html | truncate: 40, '' }}
              </div>

              <!-- Короткий текст отзыва (первые 120 символов) -->
              <div class="tw:text-[1.6rem] tw:text-[#8b867a] tw:leading-[1.5] tw:tracking-[-0.04em] tw:font-medium tw:flex-1 tw:mb-6">
                {{ review.comment | strip_html | truncate: 120 }}
              </div>

              <!-- Кнопка "Read more" (декоративная) -->
              <div class="tw:mt-auto tw:flex tw:items-center tw:justify-center tw:rounded-[0.8rem] tw:transition-colors tw:duration-300 tw:ease-in-out tw:hover:bg-golden tw:pt-1 tw:px-[1.6rem] tw:h-[3.6rem] tw:bg-grayscale-50 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium">
                <span>Read more</span>
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% comment %} ===== КНОПКА SHOW MORE ===== {% endcomment %}
      <div class="tw:flex tw:justify-center tw:mt-[2.5rem] tw:md:mt-[4rem]">
        <button type="button" id="reviews-show-more-btn" class="tw:inline-flex tw:items-center tw:justify-center tw:rounded-full tw:transition-colors tw:duration-300 tw:ease-in-out tw:hover:bg-golden tw:px-[1.6rem] tw:pt-1 tw:h-[3.6rem] tw:bg-white tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:font-medium tw:shadow-md disabled:tw:opacity-70 disabled:tw:cursor-not-allowed">
          <svg id="reviews-loader" class="tw:hidden tw:animate-spin tw:mr-2 tw:h-5 tw:w-5 tw:text-goluboydark" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="tw:opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="tw:opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
          <span id="reviews-btn-text">Show More Reviews</span>
        </button>
      </div>
    </div>
  </div>
{% endif %}

<script>
  function initReviews() {
    const grid = document.getElementById('reviews-grid');
    const btn = document.getElementById('reviews-show-more-btn');
    const loader = document.getElementById('reviews-loader');
    const btnText = document.getElementById('reviews-btn-text');

    if (!grid) return;
    const items = grid.querySelectorAll('.review-item');

    if (items.length === 0) {
      if (btn) btn.style.display = 'none';
      return;
    }

    // Сброс состояния
    if (btn) {
      btn.style.display = '';
      btn.disabled = false;
      if (loader) loader.style.display = 'none';
      if (btnText) btnText.textContent = 'Show More Reviews';
    }

    items.forEach((item) => {
      item.classList.add('tw:hidden');
      item.classList.remove('review-item-animate');
    });

    grid.dataset.visible = 0;

    function getCSSVar(varName) {
      return parseInt(getComputedStyle(grid).getPropertyValue(varName)) || 1;
    }

    function showItems(count) {
      let currentVisible = parseInt(grid.dataset.visible) || 0;
      const totalToShow = Math.min(currentVisible + count, items.length);

      for (let i = currentVisible; i < totalToShow; i++) {
        items[i].classList.remove('tw:hidden');
        items[i].classList.add('review-item-animate');
      }

      grid.dataset.visible = totalToShow;

      if (totalToShow >= items.length) {
        if (btn) btn.style.display = 'none';
      }
    }

    const initialItems = getCSSVar('--initial-items');
    showItems(initialItems);
  }

  // Глобальный слушатель для кнопки
  if (!window.reviewsListenerAdded) {
    document.addEventListener('click', function (e) {
      const btn = e.target.closest('#reviews-show-more-btn');
      if (btn && !btn.disabled) {
        const grid = document.getElementById('reviews-grid');
        const loader = document.getElementById('reviews-loader');
        const btnText = document.getElementById('reviews-btn-text');

        if (!grid) return;

        btn.disabled = true;
        if (loader) loader.style.display = 'inline-block';
        if (btnText) btnText.textContent = 'Loading...';

        setTimeout(function () {
          if (loader) loader.style.display = 'none';
          if (btnText) btnText.textContent = 'Show More Reviews';
          btn.disabled = false;

          const gridCols = parseInt(getComputedStyle(grid).getPropertyValue('--grid-cols')) || 1;

          let currentVisible = parseInt(grid.dataset.visible) || 0;
          const items = grid.querySelectorAll('.review-item');
          const totalToShow = Math.min(currentVisible + gridCols, items.length);

          for (let i = currentVisible; i < totalToShow; i++) {
            items[i].classList.remove('tw:hidden');
            items[i].classList.add('review-item-animate');
          }

          grid.dataset.visible = totalToShow;

          if (totalToShow >= items.length) {
            btn.style.display = 'none';
          }
        }, 800);
      }
    });
    window.reviewsListenerAdded = true;
  }

  // Инициализация
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReviews);
  } else {
    initReviews();
  }

  document.addEventListener('shopify:section:load', (e) => {
    if (e.target.querySelector('#reviews-grid')) {
      initReviews();
    }
  });
</script>

