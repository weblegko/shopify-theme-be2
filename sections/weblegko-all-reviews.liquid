<!-- sections/weblegko-all-reviews.liquid -->

{% comment %}
Создай метаобъект Product Review:  custom_product_review;

Создай в нем поля :  product (тип Product)
                     title (Single line text)  
                     comment (Multi line text)     
                     rating (Integer)
                     author (Single Line text)      
                     created_at (Date and Time);   
Создай несколько вхождений; 
{% endcomment %}


{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

<style>
  /* ============================================ */
  /* ПАДДИНГИ СЕКЦИИ (rem) - inline стили */
  /* ============================================ */
  .weblegko-reviews-padding {
    padding-top: {{ section.settings.padding_top_mobile | default: 3 }}rem !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 3 }}rem !important;
  }

  @media screen and (min-width: 640px) {
    .weblegko-reviews-padding {
      padding-top: {{ section.settings.padding_top_tablet | default: 5 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_tablet | default: 5 }}rem !important;
    }
  }

  @media screen and (min-width: 1024px) {
    .weblegko-reviews-padding {
      padding-top: {{ section.settings.padding_top_desktop | default: 8 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 8 }}rem !important;
    }
  }

  /* ============================================ */
  /* GRID С БРЕЙКПОИНТАМИ (колонки, gap, initial items) */
  /* ============================================ */

  #reviews-grid {
    display: grid !important;
    grid-template-columns: repeat({{ section.settings.columns_mobile | default: 1 }}, 1fr) !important;
    gap: {{ section.settings.row_gap_mobile | default: 1.5 }}rem {{ section.settings.col_gap_mobile | default: 1.5 }}rem !important;
    --grid-cols: {{ section.settings.columns_mobile | default: 1 }};
    --initial-items: {{ section.settings.initial_items_mobile | default: 1 }};
  }

  @media screen and (min-width: 640px) and (max-width: 1023px) {
    #reviews-grid {
      grid-template-columns: repeat({{ section.settings.columns_tablet | default: 2 }}, 1fr) !important;
      gap: {{ section.settings.row_gap_tablet | default: 2 }}rem {{ section.settings.col_gap_tablet | default: 2 }}rem !important;
      --grid-cols: {{ section.settings.columns_tablet | default: 2 }};
      --initial-items: {{ section.settings.initial_items_tablet | default: 2 }};
    }
  }

  @media screen and (min-width: 1024px) {
    #reviews-grid {
      grid-template-columns: repeat({{ section.settings.columns_desktop | default: 3 }}, 1fr) !important;
      gap: {{ section.settings.row_gap_desktop | default: 2.5 }}rem {{ section.settings.col_gap_desktop | default: 2.5 }}rem !important;
      --grid-cols: {{ section.settings.columns_desktop | default: 3 }};
      --initial-items: {{ section.settings.initial_items_desktop | default: 3 }};
    }
  }

  /* ============================================ */
  /* Анимация "вырастания" карточки снизу */
  /* ============================================ */
  @keyframes fadeGrowIn {
    from {
      opacity: 0;
      transform: translateY(2rem) scale(0.98);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .review-item-animate {
    animation: fadeGrowIn 0.5s ease-out forwards;
  }
</style>

<!-- Фолбэк для отключенного JS: показываем все карточки и прячем кнопку -->
<noscript>
  <style>
    .review-item.tw\:hidden {
      display: block !important;
    }
    #reviews-show-more-btn {
      display: none !important;
    }
  </style>
</noscript>

