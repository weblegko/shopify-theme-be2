<!-- snippets/icon-cart-bubble.liquid -->

<svg
  class="tw:shrink-0 tw:w-[2.4rem] tw:h-[2.4rem] tw:xl:w-[2rem] tw:xl:h-[2rem]"
  focusable="false"
  aria-hidden="true"
>
  <use href="#cart"></use>
</svg>

<span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>

{%- if cart.item_count > 0 -%}
  <div class="cart-count-bubble tw:!bg-goluboy tw:absolute tw:top-[0.4rem] tw:!left-[2.2rem] tw:flex tw:items-center tw:justify-center tw:min-w-[2rem] tw:h-[2rem] tw:rounded-full tw:bg-goluboy tw:text-white tw:text-[1.2rem] tw:font-bold tw:leading-none tw:px-[0.4rem] tw:border-2 tw:border-white tw:shadow-sm">
    <span aria-hidden="true">{{ cart.item_count }}</span>
  </div>
{%- endif -%}




{% comment %} {% if cart == empty %}
  <span class="svg-wrapper">{{ 'icon-cart-empty.svg' | inline_asset_content }}</span>
{% else %}
  <span class="svg-wrapper">{{ 'icon-cart.svg' | inline_asset_content }}</span>
{% endif %}

<span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
{%- if cart != empty -%}
  <div class="cart-count-bubble">
    {%- if cart.item_count < 100 -%}
      <span aria-hidden="true">{{ cart.item_count }}</span>
    {%- endif -%}
    <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
  </div>
{%- endif -%}
 {% endcomment %}
