      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 8,
      "unit": "rem",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "💻 Tablet (640px - 1024px)"
    },
    {
      "type": "range",
      "id": "space_between_tablet",
