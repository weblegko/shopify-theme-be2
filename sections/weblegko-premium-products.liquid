<!-- sections/weblegko-premium-products.liquid -->

{%- style -%}
   /* Кастомная пагинация для премиум-слайдера */
   .premium-pagination {
     margin-top: 3rem;
   }
   /* Кастомная пагинация для премиум-слайдера */
  .premium-pagination .custom-bullet {
     width: 4rem !important;
     height: 0.3rem !important;
     border-radius: 0.2rem !important;
     background: rgba(0, 0, 0, 0.15) !important;
     cursor: pointer;
     transition: all 0.3s ease;
     position: relative;
     overflow: hidden;
   }

   .premium-pagination .custom-bullet .bullet-progress {
     position: absolute;
     top: 0;
     left: 0;
     height: 100%;
     background: #1a1a1a;
     border-radius: 0.2rem;
     transition: width 0.3s ease;
     width: 0%;
   }

   .premium-pagination .custom-bullet.active .bullet-progress {
     background: #1a1a1a;
   }

   .premium-pagination .custom-bullet:hover {
     background: rgba(0, 0, 0, 0.25) !important;
   }

   /* Скрываем стандартные булеты Swiper */
   .premium-pagination .swiper-pagination-bullet {
     display: none !important;
   }

   /* ===== ОДИНАКОВАЯ ВЫСОТА СЛАЙДОВ ===== */

   /* Сбрасываем фиксированную высоту Swiper-контейнера */
   .premiumSwiper.swiper {
     height: auto !important;
     user-select: none;
   }

   /* Wrapper растягивается по содержимому, слайды выравниваются по высоте */
   .premiumSwiper .swiper-wrapper {
     height: auto !important;
     align-items: stretch !important;
   }

   /* Каждый слайд растягивается на всю высоту wrapper */
   .premiumSwiper .swiper-slide {
     height: auto !important;
     align-self: stretch !important;
     display: flex !important;
   }

   /* Внутренний контейнер слайда — flex-column на всю высоту */
   .premiumSwiper .swiper-slide > div {
     display: flex !important;
     flex-direction: column !important;
     height: 100% !important;
     width: 100% !important;
   }

   /* ============================================ */
   /* ПАДДИНГИ СЕКЦИИ (rem) - inline стили */
   /* ============================================ */
   .weblegko-premium-padding {
     padding-top: {{ section.settings.padding_top_mobile | default: 3 }}rem !important;
     padding-bottom: {{ section.settings.padding_bottom_mobile | default: 3 }}rem !important;
   }

   @media screen and (min-width: 640px) {
     .weblegko-premium-padding {
       padding-top: {{ section.settings.padding_top_tablet | default: 5 }}rem !important;
       padding-bottom: {{ section.settings.padding_bottom_tablet | default: 5 }}rem !important;
     }
   }

   @media screen and (min-width: 1024px) {
     .weblegko-premium-padding {
       padding-top: {{ section.settings.padding_top_desktop | default: 8 }}rem !important;
       padding-bottom: {{ section.settings.padding_bottom_desktop | default: 8 }}rem !important;
     }
   }
{%- endstyle -%}

<section class="tw:bg-seriy tw:text-grayscale-950 tw:px-[1.6rem]">
  <div class="weblegko-premium-padding tw:max-w-[115rem] tw:mx-auto">
    <!-- Заголовок -->
    {%- if section.settings.heading != blank -%}
      <div class="tw:flex tw:flex-col tw:items-center tw:gap-[1rem] tw:mb-[2.5rem]">
        <h2 class="tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.33] tw:md:leading-[1.2] tw:text-center">
          {{ section.settings.heading }}
        </h2>
        {%- if section.settings.description != blank -%}
          <div class="tw:mx-auto tw:inline-flex tw:items-center tw:justify-center tw:gap-2 tw:py-[0.8rem] tw:px-[2rem] tw:bg-[#e5dccb] tw:rounded-full">
            <span class="tw:pt-1 tw:text-[1.4rem] tw:leading-[1.43] tw:tracking-[-0.04em] tw:text-center">
              {{ section.settings.description }}
            </span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {% comment %} дополнительный контейнер для ховер теней {% endcomment %}
    <div class="tw:sm:pt-[1rem] tw:sm:pb-[2rem] tw:sm:mx-auto tw:sm:max-w-[115rem] tw:sm:!overflow-hidden">
      <!-- Слайдер -->
      <div class="tw:mx-auto tw:max-w-[112rem] swiper premiumSwiper tw:relative tw:!overflow-visible">
        <div class="swiper-wrapper">
          {%- if section.settings.collection != blank -%}
            {%- assign skip_card_product_styles = false -%}
            {%- for product in section.settings.collection.products -%}
              {%- assign lazy_load = false -%}
              {%- if forloop.index > 2 -%}
                {%- assign lazy_load = true -%}
              {%- endif -%}
              <div class="swiper-slide tw:h-auto">
                <div class="tw:h-[inherit]">
                  {% render 'card-product-premium',
                    card_product: product,
                    media_aspect_ratio: section.settings.image_ratio,
                    image_shape: section.settings.image_shape,
                    show_secondary_image: section.settings.show_secondary_image,
                    show_vendor: section.settings.show_vendor,
                    show_rating: section.settings.show_rating,
                    lazy_load: lazy_load,
                    skip_styles: skip_card_product_styles,
                    quick_add: section.settings.quick_add,
                    section_id: section.id
                  %}
                </div>
              </div>
              {%- assign skip_card_product_styles = true -%}
            {%- endfor -%}

          {%- else -%}
            <!-- Плейсхолдеры -->
            {%- for i in (1..3) -%}
              <div class="swiper-slide tw:h-auto">
                <div class="tw:block tw:px-[0.8rem] tw:pt-[0.8rem] tw:pb-[1.6rem] tw:rounded-[1.6rem] tw:bg-white tw:mx-[0.5rem]">
                  <div class="tw:aspect-square tw:bg-[#f2f1ed] tw:rounded-[0.8rem] tw:flex tw:items-center tw:justify-center tw:mb-[1.6rem]">
                    {{ 'product-1' | placeholder_svg_tag: 'tw:w-[6rem] tw:h-[6rem] tw:text-[#d4d4d4]' }}
                  </div>
                  <div class="tw:px-[1rem]">
                    <div class="tw:h-[1.6rem] tw:w-[70%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[0.8rem]"></div>
                    <div class="tw:h-[1.2rem] tw:w-[100%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[0.4rem]"></div>
                    <div class="tw:h-[1.2rem] tw:w-[60%] tw:bg-[#f2f1ed] tw:rounded-full tw:mb-[1.2rem]"></div>
                    <div class="tw:h-[1.4rem] tw:w-[40%] tw:bg-[#f2f1ed] tw:rounded-full"></div>
                  </div>
                </div>
              </div>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>

    <!-- Пагинация -->
    <div class="premium-pagination tw:flex tw:md:hidden tw:justify-center tw:gap-[0.8rem]"></div>
  </div>
</section>

<script>
    function initPremiumSlider() {
      if (typeof Swiper !== 'undefined') {
        const sliderEl = document.querySelector('.premiumSwiper');
        if (sliderEl && !sliderEl.classList.contains('swiper-initialized')) {
          // Получаем количество реальных слайдов (без дублей)
          const slides = sliderEl.querySelectorAll('.swiper-slide');
          // Фильтруем дубли (у них есть класс swiper-slide-duplicate)
          const realSlides = sliderEl.querySelectorAll('.swiper-slide:not(.swiper-slide-duplicate)');
          const totalSlides = realSlides.length;


          if (totalSlides === 0) {
            // Скрываем пагинацию
            const paginationEl = document.querySelector('.premium-pagination');
            if (paginationEl) paginationEl.style.display = 'none';
            return;
          }

          // Определяем количество булетов (максимум 3)
          const bulletsCount = Math.min(totalSlides, 3);

          // Получаем контейнер пагинации
          const paginationEl = document.querySelector('.premium-pagination');

          // Очищаем контейнер
          paginationEl.innerHTML = '';

          // Создаем кастомные булеты
          for (let i = 0; i < bulletsCount; i++) {
            const bullet = document.createElement('span');
            bullet.className = 'custom-bullet';
            bullet.dataset.index = i;

            // Создаем прогресс-бар
            const progress = document.createElement('span');
            progress.className = 'bullet-progress';
            progress.style.width = '0%';

            bullet.appendChild(progress);
            paginationEl.appendChild(bullet);
          }

          // Получаем настройки отступов из схемы
          const spaceBetweenMobile = {{ section.settings.space_between_mobile | default: 1 | times: 10 }};
          const spaceBetweenTablet = {{ section.settings.space_between_tablet | default: 2 | times: 10 }};
          const spaceBetweenDesktop = {{ section.settings.space_between_desktop | default: 2 | times: 10 }};

          // Инициализируем Swiper с отключенной пагинацией
          const swiper = new Swiper('.premiumSwiper', {
            slidesPerView: 1,
            spaceBetween: spaceBetweenMobile,
            loop: totalSlides > 3 ? true : false,
            speed: 600,
            autoplay: {
              delay: 4000,
              disableOnInteraction: false,
            },
            // Отключаем стандартную пагинацию
            pagination: false,
            breakpoints: {
              0: {
                slidesPerView: 1.045,
                spaceBetween: spaceBetweenMobile,
              },
              640: {
                slidesPerView: 2,
                spaceBetween: spaceBetweenTablet,
              },
              1024: {
                slidesPerView: 3,
                spaceBetween: spaceBetweenDesktop,
              },
            },
          });

          // Функция обновления булетов
          function updateBullets(swiperInstance) {
            // Используем realIndex для определения текущего слайда
            let currentIndex = swiperInstance.realIndex;

            // Если loop включен, realIndex может быть больше общего количества
            // Нормализуем индекс
            if (totalSlides > 3) {
              currentIndex = currentIndex % totalSlides;
            }

            const bullets = document.querySelectorAll('.premium-pagination .custom-bullet');

            if (bullets.length === 0) return;

            const bulletsCount = bullets.length;

            bullets.forEach((bullet, idx) => {
              // Определяем диапазон слайдов для этого булета
              let start = Math.round((idx / bulletsCount) * totalSlides);
              let end = Math.round(((idx + 1) / bulletsCount) * totalSlides);

              // Для последнего булета включаем все оставшиеся
              if (idx === bulletsCount - 1) {
                end = totalSlides;
              }

              // Проверяем активность
              const isActive = currentIndex >= start && currentIndex < end;
              bullet.classList.toggle('active', isActive);

              // Вычисляем прогресс
              let progress = 0;
              if (isActive) {
                const positionInGroup = currentIndex - start;
                const groupSize = end - start;
                progress = (positionInGroup / groupSize) * 100;
              } else if (currentIndex >= end) {
                progress = 100;
              }

              // Обновляем прогресс-бар
              const progressBar = bullet.querySelector('.bullet-progress');
              if (progressBar) {
                progressBar.style.width = Math.min(Math.max(progress, 0), 100) + '%';
              }

              // Обработчик клика
              bullet.onclick = function() {
                // Вычисляем target индекс
                const targetIndex = Math.round((idx / bulletsCount) * totalSlides);
                // Если loop включен, добавляем смещение
                if (totalSlides > 3) {
                  // Находим ближайший слайд с нужным индексом в loop режиме
                  const slides = swiperInstance.slides;
                  let targetSlideIndex = -1;
                  for (let i = 0; i < slides.length; i++) {
                    if (!slides[i].classList.contains('swiper-slide-duplicate')) {
                      const slideIndex = parseInt(slides[i].getAttribute('data-swiper-slide-index'));
                      if (slideIndex === targetIndex) {
                        targetSlideIndex = i;
                        break;
                      }
                    }
                  }
                  if (targetSlideIndex !== -1) {
                    swiperInstance.slideTo(targetSlideIndex);
                  }
                } else {
                  swiperInstance.slideTo(targetIndex);
                }
              };
            });
          }

          // Обновляем булеты при событиях
          swiper.on('init', function() {
            setTimeout(() => updateBullets(this), 100);
          });

          swiper.on('slideChange', function() {
            updateBullets(this);
          });

          swiper.on('resize', function() {
            updateBullets(this);
          });

          // Сохраняем ссылку
          sliderEl.swiper = swiper;
        }
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPremiumSlider);
    } else {
      initPremiumSlider();
    }

    document.addEventListener('shopify:section:load', function (e) {
      if (e.target.querySelector('.premiumSwiper')) {
        const oldSlider = e.target.querySelector('.premiumSwiper.swiper-initialized');
        if (oldSlider && oldSlider.swiper) {
          oldSlider.swiper.destroy(true, true);
        }
        // Очищаем пагинацию
        const paginationEl = document.querySelector('.premium-pagination');
        if (paginationEl) {
          paginationEl.innerHTML = '';
        }
        initPremiumSlider();
      }
    });
</script>

{% schema %}
{
  "name": "WEBLEGKO PREMIUM",
  "tag": "section",
  "class": "section-premium-products",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Premium Products",
      "label": "Heading"
    },
    {
      "type": "text",
      "id": "description",
      "default": "Premium supplements for your health",
      "label": "Description Badge"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "header",
      "content": "🖥️ Desktop (≥ 1024px)"
    },
    {
      "type": "range",
      "id": "space_between_desktop",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 2,
      "unit": "rem",
      "label": "Space between slides"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 8,
