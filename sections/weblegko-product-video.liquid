<!-- sections/weblegko-prod-video.liquid -->

{{ 'video-section.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

<style>
  /* ============================================ */
  /* ПАДДИНГИ СЕКЦИИ (rem) - inline стили */
  /* ============================================ */
  .weblegko-video-padding {
    padding-top: {{ section.settings.padding_top_mobile | default: 3 }}rem !important;
    padding-bottom: {{ section.settings.padding_bottom_mobile | default: 3 }}rem !important;
    padding-left: {{ section.settings.padding_inline_mobile | default: 1.6 }}rem !important;
    padding-right: {{ section.settings.padding_inline_mobile | default: 1.6 }}rem !important;
  }

  @media screen and (min-width: 640px) {
    .weblegko-video-padding {
      padding-top: {{ section.settings.padding_top_tablet | default: 5 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_tablet | default: 5 }}rem !important;
      padding-left: {{ section.settings.padding_inline_tablet | default: 3 }}rem !important;
      padding-right: {{ section.settings.padding_inline_tablet | default: 3 }}rem !important;
    }
  }

  @media screen and (min-width: 1024px) {
    .weblegko-video-padding {
      padding-top: {{ section.settings.padding_top_desktop | default: 8 }}rem !important;
      padding-bottom: {{ section.settings.padding_bottom_desktop | default: 8 }}rem !important;
      padding-left: {{ section.settings.padding_inline_desktop | default: 5 }}rem !important;
      padding-right: {{ section.settings.padding_inline_desktop | default: 5 }}rem !important;
    }
  }
</style>

{%- liquid
  assign video_id = section.settings.video.id | default: section.settings.video_url.id
  assign video_alt = section.settings.video.alt | default: section.settings.description
  assign alt = 'sections.video.load_video' | t: description: video_alt | escape
  assign poster = section.settings.video.preview_image | default: section.settings.cover_image
  assign cover_url = section.settings.cover_image | image_url: width: 3840

  if section.settings.video != null
    assign ratio_diff = section.settings.video.aspect_ratio | minus: poster.aspect_ratio | abs
    if ratio_diff < 0.01 and ratio_diff > 0
      assign fix_ratio = true
    endif
  endif
-%}

{%- capture sizes -%}100%{%- endcapture -%}

<div class="tw:px-[1.6rem] gradient">
  <div class="tw:mx-auto tw:max-w-[112rem] weblegko-video-padding video-section isolate">
    <div class="block">
      {%- unless section.settings.heading == blank -%}
        <div class="tw:mb-[1rem] {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
          <h2 class="tw:text-grayscale-950 tw:text-[2.4rem] tw:sm:text-[4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.33] tw:lg:leading-[1.2] tw:text-center 
            inline-richtext">{{ section.settings.heading }}</h2>
        </div>
      {%- endunless -%}
    </div>
    <deferred-media
      class="video-section__media deferred-media{% if section.settings.full_width %} global-media-settings--full-width{% endif %}{% if fix_ratio %} media-fit-cover{% endif %}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
      data-media-id="{{ video_id }}"
      {% if poster != null %}
        style="--ratio-percent: {{ 1 | divided_by: poster.aspect_ratio | times: 100 }}%;"
      {% endif %}
    >
      <!-- ТРИГГЕР -->
      <button
        class="tw:w-full tw:absolute tw:inset-0 tw:overflow-hidden tw:aspect-video tw:cursor-pointer tw:bg-black tw:group"
        id="Deferred-Poster-Modal-{{ video_id }}"
        type="button"
        aria-label="{{ alt }}"
      >
        {%- if poster != null -%}
          {%- if cover_url != null -%}
            {%- assign img_width = 3840 -%}
            {%- assign img_height = img_width | divided_by: poster.aspect_ratio -%}
            <img
              src="{{ cover_url }}"
              alt="{{ alt }}"
              width="{{ img_width }}"
              height="{{ img_height }}"
              class="tw:w-full tw:h-full tw:object-cover tw:transition-transform tw:duration-500 group-hover:tw:scale-105"
              loading="lazy"
            >
          {%- else -%}
            {{
              poster
              | image_url: width: 3840
              | image_tag: sizes: sizes, widths: '375, 750, 1100, 1500, 1780, 2000, 3000, 3840', alt: alt
            }}
          {%- endif -%}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'tw:w-full tw:h-full tw:object-cover' }}
        {%- endif -%}

        <div class="tw:absolute tw:inset-0 tw:bg-black/30"></div>

        <div class="tw:absolute tw:inset-0 tw:flex tw:flex-col tw:items-center tw:justify-center">
          <div class="tw:hover:scale-105 tw:flex tw:items-center tw:gap-[0.8rem] tw:px-[1.6rem] tw:h-[4.4rem] tw:bg-black/30 tw:rounded-full tw:text-white tw:transition-all tw:duration-200 tw:hover:bg-goluboy">
            <svg class="tw:w-[1.4rem] tw:h-[1.7rem]" focusable="false" aria-hidden="true">
              <use href="#play"></use>
            </svg>
            <span class="tw:text-[1.4rem] tw:font-medium tw:tracking-[-0.04em] tw:leading-[1.43]">Watch Video</span>
          </div>
        </div>
      </button>

      <template>
        {%- if section.settings.video == null and section.settings.video_url != null -%}
          {%- liquid
            assign loop = ''
            if section.settings.enable_video_looping
              assign loop = '&loop=1&playlist=' | append: video_id
            endif
          -%}
          {%- if section.settings.video_url.type == 'youtube' -%}
            <iframe
              src="https://www.youtube.com/embed/{{ video_id }}?enablejsapi=1&autoplay=1{{ loop }}"
              class="js-youtube"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- else -%}
            <iframe
              src="https://player.vimeo.com/video/{{ video_id }}?autoplay=1{{ loop }}"
              class="js-vimeo"
              allow="autoplay; encrypted-media"
              allowfullscreen
              title="{{ section.settings.description | escape }}"
            ></iframe>
          {%- endif -%}
        {%- else -%}
          {{
            section.settings.video
            | video_tag:
              image_size: '1100x',
              autoplay: true,
              loop: section.settings.enable_video_looping,
              controls: true,
              muted: false
          }}
        {%- endif -%}
      </template>
    </deferred-media>
  </div>
</div>

{% schema %}
{
  "name": "WEBLEGKO PROD VIDEO",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Product Video",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h2",
          "label": "Small"
        },
        {
          "value": "h1",
          "label": "Medium"
        },
        {
          "value": "h0",
          "label": "Large"
        },
        {
          "value": "hxl",
          "label": "Extra Large"
        },
        {
          "value": "hxxl",
          "label": "Extra Extra Large"
        }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "checkbox",
      "id": "enable_video_looping",
      "label": "Enable video looping",
      "default": false
    },
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "video",
      "id": "video",
      "label": "Video file"
    },
    {
      "type": "header",
      "content": "External video"
    },
    {
      "type": "paragraph",
      "content": "Use YouTube or Vimeo if you don't have a video file"
    },
    {
      "type": "video_url",
      "id": "video_url",
      "accept": ["youtube", "vimeo"],
      "default": "https://www.youtube.com/watch?v=_9VUPq3SxOc",
      "label": "Video URL",
      "info": "YouTube or Vimeo link"
    },
    {
      "type": "image_picker",
      "id": "cover_image",
      "label": "Cover image"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Video description",
      "info": "Used for accessibility"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "default": false
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "🖥️ Desktop (≥ 1024px)"
    },
    {
      "type": "range",
      "id": "padding_inline_desktop",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 5,
      "unit": "rem",
      "label": "Horizontal padding (left/right)"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 8,
      "unit": "rem",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 20,
      "step": 0.5,
      "default": 8,
      "unit": "rem",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "💻 Tablet (640px - 1024px)"
    },
    {
      "type": "range",
      "id": "padding_inline_tablet",
      "min": 0,
      "max": 8,
      "step": 0.5,
      "default": 3,
      "unit": "rem",
      "label": "Horizontal padding (left/right)"
    },
    {
      "type": "range",
      "id": "padding_top_tablet",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "default": 5,
      "unit": "rem",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_tablet",
      "min": 0,
      "max": 15,
      "step": 0.5,
      "default": 5,
      "unit": "rem",
      "label": "Padding bottom"
    },
    {
      "type": "header",
      "content": "📱 Mobile (< 640px)"
    },
    {
      "type": "range",
      "id": "padding_inline_mobile",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "default": 1.5,
      "unit": "rem",
      "label": "Horizontal padding (left/right)"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 3,
      "unit": "rem",
      "label": "Padding top"
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "default": 3,
      "unit": "rem",
      "label": "Padding bottom"
    }
  ],
  "presets": [
    {
      "name": "WEBLEGKO PROD VIDEO",
      "category": "Product"
    }
  ]
}
{% endschema %}
